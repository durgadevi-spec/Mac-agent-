{
  "manifest_version": 3,
  "name": "Knockturn Monitor Link",
  "version": "1.0.0",
  "description": "Integrates Chrome activity with the Knockturn productivity tracker.",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
