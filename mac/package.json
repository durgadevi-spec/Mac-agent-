{
  "name": "knockturn-employee-agent-mac",
  "description": "Knockturn Employee Productivity Agent - macOS Version",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/electron/main.mac.js",
  "homepage": "./",
  "scripts": {
    "clean": "rm -rf dist/app dist/electron",
    "dev": "vite",
    "dev:mac": "electron dist/electron/main.mac.js",
    "build": "vite build && npm run build:mac:electron",
    "build:mac:electron": "tsc --project mac/tsconfig.mac.json && cp electron/preload.cjs dist/electron/preload.cjs",
    "build:mac:dmg": "npm run build && electron-builder --mac --config.directories.output=release/mac",
    "build:mac:universal": "npm run build && electron-builder --mac --universal --config.directories.output=release/mac",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@types/react-datepicker": "^6.2.0",
    "date-fns": "^4.3.0",
    "dotenv": "^17.4.2",
    "electron-is-dev": "^2.0.0",
    "lucide-react": "^0.344.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1",
    "recharts": "^2.10.0",
    "screenshot-desktop": "^1.15.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/screenshot-desktop": "^1.15.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.9.1",
    "postcss": "^8.4.46",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.11"
  }
}
