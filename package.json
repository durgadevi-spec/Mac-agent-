{
  "name": "knockturn-employee-agent",
  "description": "Knockturn Employee Productivity Agent - Desktop App",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "dist/electron/main.js",
  "homepage": "./",
  "scripts": {
    "clean": "node -e \"import { rmSync } from 'node:fs'; rmSync('dist/app', { recursive: true, force: true }); rmSync('dist/electron', { recursive: true, force: true });\"",
    "dev": "vite",
    "dev:electron": "electron .",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc --project tsconfig.electron.json && node -e \"const fs = require('fs'); fs.copyFileSync('electron/preload.cjs', 'dist/electron/preload.cjs');\"",
    "build:windows": "npm run build && electron-builder --win --config.directories.output=release",
    "build:msi": "npm run build && electron-builder --win msi --config.directories.output=release",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "electron": "electron dist/electron/main.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@types/react-datepicker": "^6.2.0",
    "active-win": "^9.0.0",
    "auto-launch": "^5.0.0",
    "date-fns": "^4.3.0",
    "electron-is-dev": "^2.0.0",
    "lucide-react": "^0.344.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^18.3.1",
    "recharts": "^2.10.0",
    "screenshot-desktop": "^1.15.4",
    "systeminformation": "^5.31.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/auto-launch": "^5.0.5",
    "@types/electron": "^1.6.10",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/screenshot-desktop": "^1.15.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  },
  "build": {
    "appId": "com.knockturn.employee-agent",
    "productName": "Knockturn Employee Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/app/**/*",
      "dist/electron/**/*",
      "node_modules/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Knockturn Employee Agent"
    }
  }
}
